# amneziawg 1.0.20260611 forward-compat with linux-zen >= 7.1.
#
# The kernel dropped the `ipv6_stub` indirection (no more <net/ipv6_stubs.h>,
# and addrconf.h no longer declares `ipv6_stub`), so socket.c fails to build:
#
#   socket.c:139:23: error: 'ipv6_stub' undeclared (first use in this function)
#
# `ipv6_stub->ipv6_dst_lookup_flow` is the module's only use of ipv6_stub, and
# the underlying ip6_dst_lookup_flow() is still EXPORT_SYMBOL_GPL with the same
# (net, sk, fl6, final_dst) signature. Call it directly on new kernels; keep the
# stub path for older ones.
--- a/socket.c
+++ b/socket.c
@@ -136,8 +136,12 @@
 			if (cache)
 				dst_cache_reset(cache);
 		}
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(7, 1, 0)
+		dst = ip6_dst_lookup_flow(sock_net(sock), sock, &fl, NULL);
+#else
 		dst = ipv6_stub->ipv6_dst_lookup_flow(sock_net(sock), sock, &fl,
 						      NULL);
+#endif
 		if (IS_ERR(dst)) {
 			ret = PTR_ERR(dst);
 			net_dbg_ratelimited("%s: No route to %pISpfsc, error %d\n",
